{
  "name": "IPguard",
  "displayName": "vibe_IP_guard",
  "description": "",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.120.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "call.IPguard",
        "title": "IPguard"
      }
    ],
    "configuration": {
      "title": "IPguard",
      "properties": {
        "ipguard.proxyUrl": {
          "type": "string",
          "default": "http://121.196.228.134:3004",
          "description": "Base URL of the IPguard LLM proxy (connect.js), without trailing slash."
        },
        "ipguard.model": {
          "type": "string",
          "default": "deepseek-chat",
          "description": "Model name sent to /v1/chat/completions."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "proxy": "node src/connect.js"
  },
  "dependencies": {
    "@babel/parser": "^7.27.0",
    "axios": "^1.9.0",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "scanoss": "^0.40.0"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/vscode": "^1.120.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  }
}
